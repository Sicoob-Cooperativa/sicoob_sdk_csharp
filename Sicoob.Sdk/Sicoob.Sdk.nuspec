<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Sicoob.Sdk</id>
    <version>1.0.0</version>
    <authors>Sicoob</authors>
    <description>SDK Oficial do Sicoob em C#. Inclui o SicoobClient e todos os modulos de APIs.</description>
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Extensions.Http" version="8.0.1" exclude="Build,Analyzers" />
        <dependency id="Sentry" version="4.4.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>
